function v(id){return document.getElementById(id).value.trim();}

function md(raw) {
  if(!raw)return'';
  let t=raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  t=t.replace(/^### (.+)$/gm,'<h3>$1</h3>');
  t=t.replace(/^## (.+)$/gm,'<h2>$1</h2>');
  t=t.replace(/^# (.+)$/gm,'<h1>$1</h1>');
  t=t.replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>');
  t=t.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
  t=t.replace(/\*([^*\n]+?)\*/g,'<em>$1</em>');
  t=t.replace(/^---+$/gm,'<hr>');
  t=t.replace(/((?:^[-•] .+\n?)+)/gm,b=>{
    const items=b.trim().split('\n').map(l=>'<li>'+l.replace(/^[-•] /,'')+'</li>').join('');
    return'<ul>'+items+'</ul>';
  });
  t=t.replace(/((?:^\d+\. .+\n?)+)/gm,b=>{
    const items=b.trim().split('\n').map(l=>'<li>'+l.replace(/^\d+\. /,'')+'</li>').join('');
    return'<ol>'+items+'</ol>';
  });
  t=t.replace(/^&gt; (.+)$/gm,'<blockquote>$1</blockquote>');
  t=t.split(/\n\n+/).map(p=>{
    const s=p.trim();
    if(!s)return'';
    if(s.startsWith('<'))return s;
    return'<p>'+s.replace(/\n/g,'<br>')+'</p>';
  }).join('\n');
  return t;
}

function setLoading(btnId,outId,on){
  const btn=document.getElementById(btnId);
  btn.disabled=on;
  btn.style.opacity=on?'.55':'1';
  if(on) document.getElementById(outId).innerHTML='<div class="generating"><div class="spinner"></div>Claude is generating your content…</div>';
}

function showOutput(outId,raw){
  const plain=raw;
  document.getElementById(outId).innerHTML=`
    <div class="out-wrap">
      <div class="out-lbl"><span>Generated Output</span>
        <div style="display:flex;gap:7px">
          <button class="copy-btn" onclick="copyText(this,'${outId}')">Copy</button>
          <button class="copy-btn" onclick="document.getElementById('${outId}').innerHTML=''">Clear</button>
        </div>
      </div>
      <div class="out-box">${md(raw)}</div>
      <textarea id="raw-${outId}" style="display:none">${plain}</textarea>
    </div>`;
}

function showError(outId,msg){
  document.getElementById(outId).innerHTML=`<div class="err-box">⚠ ${msg}</div>`;
}

function copyText(btn,outId){
  const raw=document.getElementById('raw-'+outId);
  navigator.clipboard.writeText(raw?raw.value:document.getElementById(outId).querySelector('.out-box').innerText);
  btn.textContent='✓ Copied!';
  setTimeout(()=>btn.textContent='Copy',1800);
}

async function callClaude(prompt,btnId,outId){
  setLoading(btnId,outId,true);
  try{
    const r=await fetch('/api/proxy',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-6',
        max_tokens:1800,
        system:SYS,
        messages:[{role:'user',content:prompt}]
      })
    });
    const d=await r.json();
    if(!r.ok||d.error){
      showError(outId,d?.error?.message||'HTTP '+r.status);
    } else {
      const text=(d.content||[]).map(b=>b.text||'').join('');
      showOutput(outId,text);
    }
  } catch(e){
    showError(outId,e.message);
  } finally {
    setLoading(btnId,outId,false);
  }
}

